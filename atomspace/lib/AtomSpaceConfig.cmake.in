@PACKAGE_INIT@

include("@CMAKE_INSTALL_PREFIX@/lib/cmake/AtomSpace/AtomSpaceTargets.cmake")

# Execution depends on atomspace and atomspace depends on execution,
# but circular dependencies are forbidden by cmake, so dependancy
# on execution is omitted in atomspace at build time. It should be set
# here for proper linking.
if(TARGET atomspace::execution)
	set_property(TARGET atomspace::execution
		APPEND PROPERTY INTERFACE_LINK_LIBRARIES
		atomspace::atomspace
	)
endif()

if(TARGET atomspace::query-engine)
	set_property(TARGET atomspace::query-engine
		APPEND PROPERTY INTERFACE_LINK_LIBRARIES
		atomspace::pattern
		atomspace::atomspace
	)
endif()

if(TARGET atomspace::truthvalue)
	set_property(TARGET atomspace::truthvalue
		APPEND PROPERTY INTERFACE_LINK_LIBRARIES
		atomspace::execution
	)
endif()

if(TARGET atomspace::atom_types)
	set_property(TARGET atomspace::atom_types
		APPEND PROPERTY INTERFACE_LINK_LIBRARIES
		atomspace::atombase
	)
endif()

# These names are used in various projects e.g. opencog, as-moses, etc.
# XXX FIXME ... they probably should not be! It would be best if the all
# of the libs were specified i.e. LINK_LIBRARIES(${ATOMSPACE_LIBRARIES})
set(ATOMSPACE_LIBRARY atomspace::atomspace)
set(ATOMSPACE_atombase_LIBRARY atomspace::atombase)
set(ATOMSPACE_atomcore_LIBRARY atomspace::atomcore)
set(ATOMSPACE_atomflow_LIBRARY atomspace::atomflow)
set(ATOMSPACE_atomproto_LIBRARY atomspace::value)
set(ATOMSPACE_atomspace_LIBRARY atomspace::atomspace)
set(ATOMSPACE_atomtypes_LIBRARY atomspace::atom_types)
set(ATOMSPACE_clearbox_LIBRARY atomspace::clearbox)
set(ATOMSPACE_execution_LIBRARY atomspace::execution)
set(ATOMSPACE_grounded_LIBRARY atomspace::grounded)
set(ATOMSPACE_join_LIBRARY atomspace::join)
set(ATOMSPACE_json_LIBRARY atomspace::json)
set(ATOMSPACE_pattern_LIBRARY atomspace::pattern)
set(ATOMSPACE_load_scm_LIBRARY atomspace::load_scm)
set(ATOMSPACE_persist_LIBRARY atomspace::persist)
set(ATOMSPACE_sexpr_LIBRARY atomspace::sexpr)
set(ATOMSPACE_smob_LIBRARY atomspace::smob)
set(ATOMSPACE_truthvalue_LIBRARY atomspace::truthvalue)
set(ATOMSPACE_value_LIBRARY atomspace::value)

# XXX why are these listed in reverse dependency order?
# Doesn't the linker care about this?
set(ATOMSPACE_LIBRARIES
	atomspace::atom_types
	atomspace::value
	atomspace::atombase
	atomspace::atomcore
	atomspace::atomflow
	atomspace::columnvec
	atomspace::truthvalue
	atomspace::clearbox
	atomspace::join
	atomspace::pattern
	atomspace::query-engine
	atomspace::execution
	atomspace::grounded
	atomspace::smob
	atomspace::atomspace
)

# Python is optional
IF (HAVE_CYTHON)
	set(ATOMSPACE_PythonEval_LIBRARY atomspace::PythonEval)
	SET(ATOMSPACE_LIBRARIES
	    atomspace::executioncontext
	    ${ATOMSPACE_LIBRARIES}
	    ${ATOMSPACE_PythonEval_LIBRARY}
	)
ENDIF (HAVE_CYTHON)

set(ATOMSPACE_DATA_DIR "@CMAKE_INSTALL_PREFIX@/share/opencog")
set(ATOMSPACE_INCLUDE_DIR "@CMAKE_INSTALL_PREFIX@/include/")
set(ATOMSPACE_VERSION "@SEMANTIC_VERSION@")
set(ATOMSPACE_FOUND 1)
